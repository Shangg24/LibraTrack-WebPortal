@model IEnumerable<HotelManagementSystem.Models.Guest>

@{
    ViewData["Title"] = "Guests";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Guests</h2>
    <a class="btn btn-primary" href="@Url.Action("Create")">New Guest</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var g in Model)
    {
        <tr>
            <td>@(g.FirstName) @g.LastName</td>
            <td>@g.Email</td>
            <td>@g.Phone</td>
            <td>
                <a class="btn btn-sm btn-secondary" href="@Url.Action("Details", new { id = g.Id })">Details</a>
                <a class="btn btn-sm btn-info" href="@Url.Action("Edit", new { id = g.Id })">Edit</a>
                <a class="btn btn-sm btn-danger" href="@Url.Action("Delete", new { id = g.Id })">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
