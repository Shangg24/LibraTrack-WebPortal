@model List<LibraTrackStudentPortal.Models.book>
@{
    var requestedBooks = ViewBag.RequestedBooks as List<string>;
    var borrowedBooks = ViewBag.BorrowedBooks as List<string>;
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">

    <h2 class="mb-0">Request a Book</h2>

    <div style="max-width:400px; position:relative; width:100%;">
        <input type="text" id="bookSearch" class="form-control"
               placeholder="Search book title or author...">

        <div id="suggestions"
             class="list-group"
             style="position:absolute; width:100%; z-index:1000;"></div>
    </div>

</div>

<br />

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Book Title</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.book_title</td>
                <td>
                    @if (borrowedBooks != null && borrowedBooks.Contains(book.id))
                    {
                        <button class="btn btn-danger btn-sm" disabled>
                            Already Borrowed
                        </button>
                    }
                    else if (requestedBooks != null && requestedBooks.Contains(book.id))
                    {
                        <button class="btn btn-secondary btn-sm" disabled>
                            Requested
                        </button>
                    }
                    else if (book.status == "Not Available")
                    {
                        <button class="btn btn-dark btn-sm" disabled>
                            Not Available
                        </button>
                    }
                    else
                    {
                        <form asp-action="SubmitRequest" method="post">
                            <input type="hidden" name="bookId" value="@book.id" />
                            <button type="submit" class="btn btn-success btn-sm">
                                Request
                            </button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    let selectedIndex = -1;

    $(document).ready(function () {

        // SEARCH
        $("#bookSearch").keyup(function (e) {

            let query = $(this).val();

            if (query.length < 1) {
                $("#suggestions").empty();
                $("table tbody tr").show();
                return;
            }

            // ignore arrow and enter
            if (e.keyCode === 38 || e.keyCode === 40 || e.keyCode === 13)
                return;

            $.ajax({
                url: '/Student/SearchBooks',
                type: 'GET',
                data: { term: query },
                success: function (data) {

                    let suggestionList = "";
                    selectedIndex = -1;

                    data.forEach(function (book) {

                        suggestionList += `
                            <a href="#" class="list-group-item list-group-item-action suggestion-item"
                               data-title="${book.book_title}">
                               <strong>${book.book_title}</strong><br>
                               <small>${book.author}</small>
                            </a>`;
                    });

                    $("#suggestions").html(suggestionList);
                }
            });

        });

        // KEYBOARD NAVIGATION
        $("#bookSearch").keydown(function (e) {

            let items = $(".suggestion-item");

            if (items.length === 0) return;

            if (e.keyCode === 40) { // down
                selectedIndex++;
                if (selectedIndex >= items.length)
                    selectedIndex = 0;
            }

            if (e.keyCode === 38) { // up
                selectedIndex--;
                if (selectedIndex < 0)
                    selectedIndex = items.length - 1;
            }

            if (e.keyCode === 13) { // enter
                e.preventDefault();

                if (selectedIndex > -1) {
                    let title = items.eq(selectedIndex).data("title");
                    selectBook(title);
                }
            }

            items.removeClass("active");

            if (selectedIndex > -1)
                items.eq(selectedIndex).addClass("active");

        });

        // CLICK SUGGESTION
        $(document).on("click", ".suggestion-item", function (e) {

            e.preventDefault();

            let title = $(this).data("title");

            selectBook(title);

        });

    });

    // SELECT BOOK
    function selectBook(title) {

        $("#bookSearch").val(title);
        $("#suggestions").empty();

        $("table tbody tr").each(function () {

            let bookTitle = $(this).find("td:first").text().trim();

            if (bookTitle.toLowerCase() === title.toLowerCase())
                $(this).show();
            else
                $(this).hide();

        });

    }
</script>