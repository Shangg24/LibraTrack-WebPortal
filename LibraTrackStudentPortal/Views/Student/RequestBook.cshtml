@model List<LibraTrackStudentPortal.Models.book>

@{
    var requestedBooks = ViewBag.RequestedBooks as List<string>;
    var borrowedBooks = ViewBag.BorrowedBooks as List<string>;
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form asp-action="SubmitRequest" method="post">

    <div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-3">
        <h2 class="mb-0">Request a Book</h2>

        <div class="request-actions">
            <div style="max-width:400px; position:relative; width:100%;">
                <input type="text" id="bookSearch" class="form-control"
                       placeholder="Search book title or author...">

                <div id="suggestions"
                     class="list-group"
                     style="position:absolute; width:100%; z-index:1000;"></div>
            </div>

            <button type="submit" class="btn submit-request-btn">
                Submit Request
            </button>
        </div>
    </div>

    <br />

    <table class="table table-bordered">
        <thead>
            <tr>
                <th style="width:80px;">Select</th>
                <th>Book Title</th>
                <th style="width:180px;">Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model)
            {
                <tr>
                    <td class="text-center">
                        @if (borrowedBooks != null && borrowedBooks.Contains(book.id))
                        {
                            <input type="checkbox" disabled />
                        }
                        else if (requestedBooks != null && requestedBooks.Contains(book.id))
                        {
                            <input type="checkbox" disabled />
                        }
                        else if (book.status == "Not Available")
                        {
                            <input type="checkbox" disabled />
                        }
                        else
                        {
                            <input type="checkbox" name="bookIds" value="@book.id" />
                        }
                    </td>

                    <td>@book.book_title</td>

                    <td>
                        @if (borrowedBooks != null && borrowedBooks.Contains(book.id))
                        {
                            <span class="badge bg-danger">Already Borrowed</span>
                        }
                        else if (requestedBooks != null && requestedBooks.Contains(book.id))
                        {
                            <span class="badge bg-secondary">Requested</span>
                        }
                        else if (book.status == "Not Available")
                        {
                            <span class="badge bg-dark">Not Available</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Available</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

</form>

<style>
    .request-actions {
        width: 400px;
        max-width: 100%;
    }

    .submit-request-btn {
        margin-top: 10px;
        background: #8b1028;
        color: #ffffff;
        border: none;
        border-radius: 10px;
        padding: 10px 18px;
        font-weight: 600;
        float: right;
    }

        .submit-request-btn:hover {
            background: #6d1023;
            color: #ffffff;
        }
</style>

<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    let selectedIndex = -1;

    $(document).ready(function () {

        $("#bookSearch").keyup(function (e) {

            let query = $(this).val();

            if (query.length < 1) {
                $("#suggestions").empty();
                $("table tbody tr").show();
                return;
            }

            if (e.keyCode === 38 || e.keyCode === 40 || e.keyCode === 13)
                return;

            $.ajax({
                url: '/Student/SearchBooks',
                type: 'GET',
                data: { term: query },
                success: function (data) {

                    let suggestionList = "";
                    selectedIndex = -1;

                    data.forEach(function (book) {
                        suggestionList += `
                            <a href="#" class="list-group-item list-group-item-action suggestion-item"
                               data-title="${book.book_title}">
                               <strong>${book.book_title}</strong><br>
                               <small>${book.author}</small>
                            </a>`;
                    });

                    $("#suggestions").html(suggestionList);
                }
            });

        });

        $("#bookSearch").keydown(function (e) {

            let items = $(".suggestion-item");

            if (items.length === 0) return;

            if (e.keyCode === 40) {
                selectedIndex++;
                if (selectedIndex >= items.length)
                    selectedIndex = 0;
            }

            if (e.keyCode === 38) {
                selectedIndex--;
                if (selectedIndex < 0)
                    selectedIndex = items.length - 1;
            }

            if (e.keyCode === 13) {
                e.preventDefault();

                if (selectedIndex > -1) {
                    let title = items.eq(selectedIndex).data("title");
                    selectBook(title);
                }
            }

            items.removeClass("active");

            if (selectedIndex > -1)
                items.eq(selectedIndex).addClass("active");

        });

        $(document).on("click", ".suggestion-item", function (e) {

            e.preventDefault();

            let title = $(this).data("title");

            selectBook(title);

        });

    });

    function selectBook(title) {

        $("#bookSearch").val(title);
        $("#suggestions").empty();

        $("table tbody tr").each(function () {

            let bookTitle = $(this).find("td:nth-child(2)").text().trim();

            if (bookTitle.toLowerCase() === title.toLowerCase())
                $(this).show();
            else
                $(this).hide();

        });

    }
</script>