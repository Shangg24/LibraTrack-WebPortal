@model List<LibraTrackStudentPortal.Models.BorrowedBooksViewModel>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="text-center mb-4">
    <h2 class="fw-bold">
        Student Dashboard
    </h2>

    <p class="text-muted fs-5">
        Welcome, @Context.Session.GetString("StudentName")
    </p>
</div>

<br />
<br />

<h3>My Borrowed Books</h3>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary dashboard-card">
            <div class="card-body text-center">
                <h5>Total Transactions</h5>
                <h2>@ViewBag.TotalTransactions</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-warning dashboard-card">
            <div class="card-body text-center">
                <h5>Currently Borrowed</h5>
                <h2>@ViewBag.CurrentBorrowed</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-success dashboard-card">
            <div class="card-body text-center">
                <h5>Total Returned</h5>
                <h2>@ViewBag.TotalReturned</h2>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">

    <!-- LEFT COLUMN -->
    <div class="col-md-6">
        <div class="card shadow h-100">
            <div class="card-header bg-warning text-white">
                <h5 class="mb-0">Currently Borrowed</h5>
            </div>
            <div class="card-body">

                <table class="table table-hover align-middle text-center">
                    <thead class="table-light">
                        <tr>
                            <th class="text-start">Book Title</th>
                            <th style="width: 120px;">Issued</th>
                            <th style="width: 120px;">Due Date</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (ViewBag.CurrentlyBorrowed != null && ViewBag.CurrentlyBorrowed.Count > 0)
                        {
                            @foreach (var item in ViewBag.CurrentlyBorrowed)
                            {
                                var isOverdue = item.Status == "Borrowed"
                                && item.ReturnDate.Date < DateTime.Now.Date;

                                <tr class="@(isOverdue ? "table-danger" : "")">
                                    <td class="text-start fw-semibold">
                                        @item.BookTitle
                                    </td>

                                    <td>
                                        @item.IssueDate.ToString("yyyy-MM-dd")
                                    </td>

                                    <td>
                                        @item.ReturnDate.ToString("yyyy-MM-dd")

                                        @if (isOverdue)
                                        {
                                            <br />
                                            <span class="badge bg-danger">Overdue</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center">No active borrowed books.</td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (ViewBag.TotalCurrentPages > 1)
                {
                    <div class="d-flex justify-content-center align-items-center gap-2 mt-3 flex-wrap">
                        @if (ViewBag.CurrentPage > 1)
                        {
                            <a href="@Url.Action("Dashboard", "Student", new { currentPage = ViewBag.CurrentPage - 1, historyPage = ViewBag.HistoryPage })" class="btn page-btn">
                                Previous
                            </a>
                        }

                        @for (int i = 1; i <= ViewBag.TotalCurrentPages; i++)
                        {
                            if (i == ViewBag.CurrentPage)
                            {
                                <span class="btn page-btn active-page">@i</span>
                            }
                            else
                            {
                                <a href="@Url.Action("Dashboard", "Student", new { currentPage = i, historyPage = ViewBag.HistoryPage })" class="btn page-btn">
                                    @i
                                </a>
                            }
                        }

                        @if (ViewBag.CurrentPage < ViewBag.TotalCurrentPages)
                        {
                            <a href="@Url.Action("Dashboard", "Student", new { currentPage = ViewBag.CurrentPage + 1, historyPage = ViewBag.HistoryPage })" class="btn page-btn">
                                Next
                            </a>
                        }
                    </div>
                }

            </div>
        </div>
    </div>

    <!-- RIGHT COLUMN -->
    <div class="col-md-6">
        <div class="card shadow h-100">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Borrowing History</h5>
            </div>
            <div class="card-body">

                <table class="table table-hover align-middle text-center">
                    <thead class="table-light">
                        <tr>
                            <th class="text-start">Book Title</th>
                            <th style="width: 110px;">Issued</th>
                            <th style="width: 110px;">Returned</th>
                            <th style="width: 100px;">Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (ViewBag.ReturnedBooks != null && ViewBag.ReturnedBooks.Count > 0)
                        {
                            @foreach (var item in ViewBag.ReturnedBooks)
                            {
                                <tr>
                                    <td class="text-start fw-semibold">
                                        @item.BookTitle
                                    </td>

                                    <td>
                                        @item.IssueDate?.ToString("yyyy-MM-dd")
                                    </td>

                                    <td>
                                        @item.ReturnDate?.ToString("yyyy-MM-dd")
                                    </td>

                                    <td>
                                        @if (item.Status == "Borrowed")
                                        {
                                            <span class="badge bg-warning text-dark">Borrowed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Returned</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center">No borrowing history yet.</td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (ViewBag.TotalHistoryPages > 1)
                {
                    <div class="d-flex justify-content-center align-items-center gap-2 mt-3 flex-wrap">
                        @if (ViewBag.HistoryPage > 1)
                        {
                            <a href="@Url.Action("Dashboard", "Student", new { currentPage = ViewBag.CurrentPage, historyPage = ViewBag.HistoryPage - 1 })" class="btn page-btn">
                                Previous
                            </a>
                        }

                        @for (int i = 1; i <= ViewBag.TotalHistoryPages; i++)
                        {
                            if (i == ViewBag.HistoryPage)
                            {
                                <span class="btn page-btn active-page">@i</span>
                            }
                            else
                            {
                                <a href="@Url.Action("Dashboard", "Student", new { currentPage = ViewBag.CurrentPage, historyPage = i })" class="btn page-btn">
                                    @i
                                </a>
                            }
                        }

                        @if (ViewBag.HistoryPage < ViewBag.TotalHistoryPages)
                        {
                            <a href="@Url.Action("Dashboard", "Student", new { currentPage = ViewBag.CurrentPage, historyPage = ViewBag.HistoryPage + 1 })" class="btn page-btn">
                                Next
                            </a>
                        }
                    </div>
                }

            </div>
        </div>
    </div>

</div>

<style>
    .page-btn {
        border: 1px solid #e7c8cf;
        background: #ffffff;
        color: #6d1023;
        border-radius: 10px;
        min-width: 44px;
        font-weight: 600;
        padding: 8px 14px;
    }

        .page-btn:hover {
            background: #f9f1f3;
            color: #4a0f1d;
        }

    .active-page {
        background: #8b1028 !important;
        color: #ffffff !important;
        border-color: #8b1028 !important;
        cursor: default;
    }
</style>