@model IEnumerable<LibraTrackStudentPortal.Models.IssueTransactionViewModel>

@{
    ViewData["Title"] = "Issue Books";
    var totalTransactionsReady = ViewBag.TotalTransactionsReady ?? 0;
    var totalReservedBooks = ViewBag.TotalReservedBooks ?? 0;
    var nextIssueId = ViewBag.NextIssueId ?? "I-0001";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1">Issue Books</h2>
            <p class="text-muted mb-0">Issue all reserved books of a student in one transaction.</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="summary-card">
                <div class="summary-label">Students Ready for Issue</div>
                <div class="summary-value">@totalTransactionsReady</div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="summary-card">
                <div class="summary-label">Reserved Books</div>
                <div class="summary-value text-primary">@totalReservedBooks</div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="summary-card">
                <div class="summary-label">Next Transaction ID</div>
                <div class="summary-value">@nextIssueId</div>
            </div>
        </div>
    </div>

    <div class="table-tools mb-3">
        <div class="search-wrap">
            <input type="text"
                   id="searchInput"
                   class="form-control search-input"
                   placeholder="Search student..." />
        </div>
    </div>

    <div class="modern-table-card">
        <div class="table-responsive">
            <table class="table modern-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Student ID</th>
                        <th>Student Name</th>
                        <th>Reserved Books</th>
                        <th>Book Titles</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var safeId = ("iss_" + (item.StudentID ?? "unknown")).Replace("-", "_");

                        <tr class="clickable-row" onclick="toggleDetails('@safeId')">
                            <td class="fw-semibold">@item.StudentID</td>
                            <td>@item.StudentName</td>
                            <td>@item.ReservedCount</td>
                            <td>@string.Join(", ", item.Books.Select(b => b.BookTitle))</td>
                            <td class="text-center" onclick="event.stopPropagation();">
                                <a href="#"
                                   class="btn action-btn btn-issue"
                                   onclick="showConfirmModal('Issue all reserved books for this student in one transaction?', '@Url.Action("ProcessIssue", new { id = item.StudentID })')">
                                    Issue Transaction
                                </a>
                            </td>
                        </tr>

                        <tr id="details-@safeId" class="detail-row" style="display:none;">
                            <td colspan="5">
                                <div class="detail-card">

                                    <div class="row mb-3 detail-info">
                                        <div class="col-md-6">
                                            <div class="info-line"><strong>Student ID:</strong> @item.StudentID</div>
                                            <div class="info-line"><strong>Student Name:</strong> @item.StudentName</div>
                                            <div class="info-line"><strong>Grade / Section:</strong> @item.GradeSection</div>
                                        </div>

                                        <div class="col-md-6">
                                            <div class="info-line"><strong>Email:</strong> @item.StudentEmail</div>
                                            <div class="info-line"><strong>Request No(s):</strong> @string.Join(", ", item.RequestNos)</div>
                                        </div>
                                    </div>

                                    <div class="table-responsive">
                                        <table class="table table-sm detail-table mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Book ID</th>
                                                    <th>Book Title</th>
                                                    <th>Author</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var book in item.Books)
                                                {
                                                    <tr>
                                                        <td>@book.BookId</td>
                                                        <td>@book.BookTitle</td>
                                                        <td>@book.Author</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">LibraTrack</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p id="confirmMessage">Are you sure?</p>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <a id="confirmBtn" class="btn btn-danger">Yes, Proceed</a>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.TotalPages > 1)
{
    <div class="d-flex justify-content-center align-items-center gap-2 mt-4 flex-wrap">
        @if (ViewBag.CurrentPage > 1)
        {
            <a href="@Url.Action("Index", "IssueBooks", new { page = ViewBag.CurrentPage - 1 })" class="btn page-btn">
                Previous
            </a>
        }

        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            if (i == ViewBag.CurrentPage)
            {
                <span class="btn page-btn active-page">@i</span>
            }
            else
            {
                <a href="@Url.Action("Index", "IssueBooks", new { page = i })" class="btn page-btn">
                    @i
                </a>
            }
        }

        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
        {
            <a href="@Url.Action("Index", "IssueBooks", new { page = ViewBag.CurrentPage + 1 })" class="btn page-btn">
                Next
            </a>
        }
    </div>
}

<style>
    .summary-card {
        background: #ffffff;
        border-radius: 18px;
        padding: 20px 22px;
        box-shadow: 0 8px 24px rgba(60, 10, 18, 0.08);
        border: 1px solid #f1d9de;
    }

    .summary-label {
        font-size: 0.95rem;
        color: #7a4b55;
        margin-bottom: 8px;
    }

    .summary-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: #4a0f1d;
    }

    .table-tools {
        display: flex;
        justify-content: flex-end;
        align-items: center;
    }

    .search-wrap {
        position: relative;
        width: 320px;
    }

    .search-input {
        border-radius: 14px;
        border: 1px solid #e7c8cf;
        padding: 12px 14px;
        min-height: 48px;
        box-shadow: 0 4px 14px rgba(60, 10, 18, 0.05);
        background: #fffdfd;
    }

        .search-input:focus {
            border-color: #8b1028;
            box-shadow: 0 0 0 0.2rem rgba(139, 16, 40, 0.12);
        }

    .modern-table-card {
        background: #ffffff;
        border-radius: 22px;
        box-shadow: 0 10px 30px rgba(60, 10, 18, 0.08);
        border: 1px solid #f1d9de;
        overflow: hidden;
    }

    .modern-table thead th {
        background: #f7e6ea;
        color: #4a0f1d;
        font-weight: 800;
        font-size: 0.95rem;
        border-bottom: 1px solid #e8c8cf;
        padding: 18px 14px;
    }

    .modern-table tbody td {
        padding: 18px 14px;
        border-color: #f6ecef;
        vertical-align: middle;
    }

    .modern-table tbody tr:hover {
        background: #fff8f9;
        cursor: pointer;
    }

    .detail-row td {
        background: #fffafb;
    }

    .detail-card {
        background: #fffdfd;
        border: 1px solid #f1d9de;
        border-radius: 16px;
        padding: 18px;
    }

    .detail-table thead th {
        background: #fdf1f3;
        color: #6d1023;
        font-weight: 700;
    }

    .detail-info .info-line {
    margin-bottom: 10px;
    font-size: 1rem;
}

    .action-btn {
        min-width: 140px;
        border-radius: 12px;
        font-weight: 600;
        padding: 8px 14px;
        border: none;
    }

    .btn-issue {
        background: #8b1028;
        color: white;
    }

        .btn-issue:hover {
            background: #6d1023;
            color: white;
        }

    .page-btn {
        border: 1px solid #e7c8cf;
        background: #ffffff;
        color: #6d1023;
        border-radius: 10px;
        min-width: 44px;
        font-weight: 600;
        padding: 8px 14px;
    }

        .page-btn:hover {
            background: #f9f1f3;
            color: #4a0f1d;
        }

    .active-page {
        background: #8b1028 !important;
        color: #ffffff !important;
        border-color: #8b1028 !important;
        cursor: default;
    }

</style>

<script>
    function showConfirmModal(message, url) {
        document.getElementById("confirmMessage").innerText = message;
        document.getElementById("confirmBtn").setAttribute("href", url);

        var modal = new bootstrap.Modal(document.getElementById('confirmModal'));
        modal.show();
    }

    function toggleDetails(id) {
        const row = document.getElementById("details-" + id);
        if (!row) return;

        if (row.style.display === "none" || row.style.display === "") {
            row.style.display = "table-row";
        } else {
            row.style.display = "none";
        }
    }

    document.getElementById("searchInput").addEventListener("keyup", function () {
        let filter = this.value.toLowerCase();
        let rows = document.querySelectorAll(".clickable-row");

        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            let safeId = ("iss_" + ((row.cells[0].innerText || "").trim())).replace(/-/g, "_");
            let detailRow = document.getElementById("details-" + safeId);

            if (text.includes(filter)) {
                row.style.display = "";
            } else {
                row.style.display = "none";
                if (detailRow) detailRow.style.display = "none";
            }
        });
    });
</script>