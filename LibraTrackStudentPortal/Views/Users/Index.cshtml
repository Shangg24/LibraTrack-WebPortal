@model IEnumerable<LibraTrackStudentPortal.Models.Users>

@{
    ViewData["Title"] = "Manage Librarian Accounts";
    var totalAccounts = Model.Count();
    var activeAccounts = Model.Count(u => u.status == "Active");
    var deactivatedAccounts = Model.Count(u => u.status == "Deactivated");
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1">Manage Librarian Accounts</h2>
            <p class="text-muted mb-0">View, create, activate, and deactivate librarian accounts.</p>
        </div>

        <a asp-action="Create" class="btn create-btn">
            + Create Librarian Account
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="summary-card">
                <div class="summary-label">Total Librarians</div>
                <div class="summary-value">@totalAccounts</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="summary-card">
                <div class="summary-label">Active</div>
                <div class="summary-value text-success">@activeAccounts</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="summary-card">
                <div class="summary-label">Deactivated</div>
                <div class="summary-value text-danger">@deactivatedAccounts</div>
            </div>
        </div>
    </div>

    <div class="table-tools mb-3">
        <div class="search-wrap">
            <i class="bi bi-search search-icon"></i>
            <input type="text"
                   id="searchInput"
                   class="form-control search-input"
                   placeholder="Search librarian..." />
        </div>
    </div>

    <div class="modern-table-card">
        <div class="table-responsive">
            <table class="table modern-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>ID Number</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Username</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-center">Account Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var safeId = ("lib_" + (user.id_number ?? "unknown")).Replace("-", "_");

                        <tr class="clickable-row" onclick="toggleDetails('@safeId')">
                            <td class="fw-semibold">@user.id_number</td>
                            <td>@user.full_name</td>
                            <td>@user.email</td>
                            <td>@user.username</td>
                            <td>@user.role</td>
                            <td>
                                @if (user.status == "Active")
                                {
                                    <span class="status-badge active-badge">Active</span>
                                }
                                else
                                {
                                    <span class="status-badge inactive-badge">Deactivated</span>
                                }
                            </td>
                            <td class="text-center" onclick="event.stopPropagation();">
                                <div class="d-flex gap-2 justify-content-center flex-wrap">
                                    <a asp-action="Edit" asp-route-id="@user.id" class="btn action-btn btn-edit">
                                        Edit
                                    </a>

                                    @if (user.status == "Deactivated")
                                    {
                                        <a href="#"
                                           class="btn action-btn btn-activate"
                                           onclick="showConfirmModal('Activate this librarian account?', '@Url.Action("Activate", new { id = user.id })')">
                                            Activate
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="#"
                                           class="btn action-btn btn-deactivate"
                                           onclick="showConfirmModal('Deactivate this librarian account?', '@Url.Action("Deactivate", new { id = user.id })')">
                                            Deactivate
                                        </a>
                                    }

                                    <a href="#"
                                       class="btn action-btn btn-warning"
                                       onclick="showConfirmModal('Reset password for this librarian?', '@Url.Action("ResetPassword", new { id = user.id })')">
                                        Reset Password
                                    </a>
                                </div>
                            </td>
                        </tr>

                        <tr id="details-@safeId" class="detail-row" style="display:none;">
                            <td colspan="7">
                                <div class="detail-card">
                                    <div class="row detail-info">
                                        <div class="col-md-4">
                                            <div class="info-line"><strong>ID Number:</strong> @user.id_number</div>
                                            <div class="info-line"><strong>Full Name:</strong> @user.full_name</div>
                                            <div class="info-line"><strong>Role:</strong> @user.role</div>
                                        </div>

                                        <div class="col-md-4">
                                            <div class="info-line"><strong>Email:</strong> @user.email</div>
                                            <div class="info-line"><strong>Username:</strong> @user.username</div>
                                        </div>

                                        <div class="col-md-4">
                                            <div class="info-line"><strong>Status:</strong> @user.status</div>
                                            <div class="info-line"><strong>Created:</strong> @(user.date_register?.ToString("MMM dd, yyyy") ?? "-")</div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="modal fade" id="confirmModal" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Confirm Action</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>

                        <div class="modal-body">
                            <p id="confirmMessage">Are you sure?</p>
                        </div>

                        <div class="modal-footer">
                            <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <a id="confirmBtn" class="btn btn-danger">Yes, Proceed</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <div class="d-flex justify-content-center align-items-center gap-2 mt-4 flex-wrap">
            @if (ViewBag.CurrentPage > 1)
            {
                <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" class="btn page-btn">
                    Previous
                </a>
            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                if (i == ViewBag.CurrentPage)
                {
                    <span class="btn page-btn active-page">@i</span>
                }
                else
                {
                    <a asp-action="Index" asp-route-page="@i" class="btn page-btn">
                        @i
                    </a>
                }
            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" class="btn page-btn">
                    Next
                </a>
            }
        </div>
    }
</div>

<style>
    .summary-card {
        background: #ffffff;
        border-radius: 18px;
        padding: 20px 22px;
        box-shadow: 0 8px 24px rgba(60, 10, 18, 0.08);
        border: 1px solid #f1d9de;
    }

    .summary-label {
        font-size: 0.95rem;
        color: #7a4b55;
        margin-bottom: 8px;
    }

    .summary-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: #4a0f1d;
    }

    .create-btn {
        background: #6d1023;
        color: #ffffff;
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
        border: none;
    }

        .create-btn:hover {
            background: #56101d;
            color: #ffffff;
        }

    .modern-table-card {
        background: #ffffff;
        border-radius: 22px;
        box-shadow: 0 10px 30px rgba(60, 10, 18, 0.08);
        border: 1px solid #f1d9de;
        overflow: hidden;
    }

    .modern-table thead th {
        background: #f7e6ea;
        color: #4a0f1d;
        font-weight: 800;
        font-size: 0.95rem;
        letter-spacing: 0.2px;
        border-bottom: 1px solid #e8c8cf;
        padding: 18px 14px;
        white-space: nowrap;
    }

    .modern-table tbody td {
        padding: 18px 14px;
        border-color: #f6ecef;
        vertical-align: middle;
    }

    .modern-table tbody tr:hover {
        background: #fff8f9;
        cursor: pointer;
    }

    .detail-row td {
        background: #fffafb;
        padding: 20px !important;
    }

    .detail-card {
        background: #fffdfd;
        border: 1px solid #f1d9de;
        border-radius: 16px;
        padding: 22px 24px;
        width: 100%;
        box-sizing: border-box;
    }

    .detail-info {
        row-gap: 10px;
    }

        .detail-info .info-line {
            margin-bottom: 10px;
            font-size: 1rem;
        }

    .status-badge {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 700;
    }

    .active-badge {
        background: rgba(34, 197, 94, 0.12);
        color: #15803d;
    }

    .inactive-badge {
        background: rgba(109, 16, 35, 0.12);
        color: #8b1028;
    }

    .action-btn {
        min-width: 120px;
        border-radius: 12px;
        font-weight: 600;
        padding: 8px 14px;
        border: none;
    }

    .btn-edit {
        background: #d97706;
        color: white;
    }

        .btn-edit:hover {
            background: #b45309;
            color: white;
        }

    .btn-activate {
        background: #15803d;
        color: white;
    }

        .btn-activate:hover {
            background: #166534;
            color: white;
        }

    .btn-deactivate {
        background: #8b1028;
        color: white;
    }

        .btn-deactivate:hover {
            background: #6d1023;
            color: white;
        }

    .table-tools {
        display: flex;
        justify-content: flex-end;
        align-items: center;
    }

    .search-wrap {
        position: relative;
        width: 320px;
    }

    .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #8b1028;
        font-size: 0.95rem;
    }

    .search-input {
        border-radius: 14px;
        border: 1px solid #e7c8cf;
        padding: 12px 14px 12px 40px;
        min-height: 48px;
        box-shadow: 0 4px 14px rgba(60, 10, 18, 0.05);
        background: #fffdfd;
    }

        .search-input:focus {
            border-color: #8b1028;
            box-shadow: 0 0 0 0.2rem rgba(139, 16, 40, 0.12);
        }

    .page-btn {
        border: 1px solid #e7c8cf;
        background: #ffffff;
        color: #6d1023;
        border-radius: 10px;
        min-width: 44px;
        font-weight: 600;
        padding: 8px 14px;
    }

        .page-btn:hover {
            background: #f9f1f3;
            color: #4a0f1d;
        }

    .active-page {
        background: #8b1028 !important;
        color: #ffffff !important;
        border-color: #8b1028 !important;
        cursor: default;
    }
</style>

<script>
    function showConfirmModal(message, url) {
        document.getElementById("confirmMessage").innerText = message;
        document.getElementById("confirmBtn").setAttribute("href", url);

        var modal = new bootstrap.Modal(document.getElementById('confirmModal'));
        modal.show();
    }

    function toggleDetails(id) {
        const row = document.getElementById("details-" + id);
        if (!row) return;

        if (row.style.display === "none" || row.style.display === "") {
            row.style.display = "table-row";
        } else {
            row.style.display = "none";
        }
    }

    document.getElementById("searchInput").addEventListener("keyup", function () {
        let filter = this.value.toLowerCase();
        let rows = document.querySelectorAll(".clickable-row");

        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            let safeId = ("lib_" + ((row.cells[0].innerText || "").trim())).replace(/-/g, "_");
            let detailRow = document.getElementById("details-" + safeId);

            if (text.includes(filter)) {
                row.style.display = "";
            } else {
                row.style.display = "none";
                if (detailRow) detailRow.style.display = "none";
            }
        });
    });
</script>