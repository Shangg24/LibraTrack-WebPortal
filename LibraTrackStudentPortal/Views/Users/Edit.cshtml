@model LibraTrackStudentPortal.Models.Users

@{
    ViewData["Title"] = "Edit Librarian Account";
}

<div class="container py-4 d-flex justify-content-center">
    <div style="width: 100%; max-width: 800px;">

        <div class="form-page-header mb-4 text-center">
            <h2 class="fw-bold mb-1">Edit Librarian Account</h2>
            <p class="text-muted mb-0">Update librarian account details.</p>
        </div>

        <div class="form-card">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mb-4">
                    @ViewBag.Error
                </div>
            }

            <form asp-action="Edit" method="post">
                <input asp-for="id" type="hidden" />

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">ID Number</label>
                        <input asp-for="id_number" class="form-control modern-input readonly-input" readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Full Name</label>
                        <input asp-for="full_name" class="form-control modern-input" placeholder="Enter full name" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Email</label>
                        <input asp-for="email" class="form-control modern-input" placeholder="Enter email" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Username</label>
                        <input asp-for="username" class="form-control modern-input" placeholder="Enter username" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Role</label>
                        <input asp-for="role" class="form-control modern-input readonly-input" readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Status</label>
                        <input asp-for="status" class="form-control modern-input readonly-input" readonly />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4 justify-content-center">
                    <button type="submit" class="btn save-btn">Save Changes</button>
                    <a asp-action="Index" class="btn cancel-btn">Back</a>
                </div>
            </form>
        </div>

    </div>
</div>

<style>
    .form-page-header h2 {
        color: #4a0f1d;
    }

    .form-card {
        background: #ffffff;
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(60, 10, 18, 0.08);
        border: 1px solid #f1d9de;
    }

    .modern-input {
        border-radius: 14px;
        border: 1px solid #e7c8cf;
        padding: 12px 14px;
        box-shadow: none;
    }

        .modern-input:focus {
            border-color: #8b1028;
            box-shadow: 0 0 0 0.2rem rgba(139, 16, 40, 0.12);
        }

    .readonly-input {
        background: #f9f1f3;
        color: #6d1023;
        font-weight: 600;
    }

    .save-btn {
        background: #8b1028;
        color: #ffffff;
        border: none;
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
    }

        .save-btn:hover {
            background: #6d1023;
            color: #ffffff;
        }

    .cancel-btn {
        background: #f3f4f6;
        color: #374151;
        border: none;
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
    }

        .cancel-btn:hover {
            background: #e5e7eb;
            color: #111827;
        }
</style>