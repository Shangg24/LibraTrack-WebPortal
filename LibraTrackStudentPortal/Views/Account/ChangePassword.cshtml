@{
    ViewData["Title"] = "Change Password";
}

<div class="container py-4">
    <div class="password-page-header mb-4">
        <h2 class="fw-bold mb-1">Change Password</h2>
        <p class="text-muted mb-0">Update your account password securely.</p>
    </div>

    <div class="password-card">
        @if (ViewBag.Success != null)
        {
            <div class="alert alert-success custom-alert mb-4">
                @ViewBag.Success
            </div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger custom-alert mb-4">
                @ViewBag.Error
            </div>
        }

        <form asp-action="ChangePassword" method="post">
            <div class="row justify-content-center g-4">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Current Password</label>
                    <div class="input-group password-group">
                        <input type="password" name="currentPassword" id="currentPassword" class="form-control modern-input" placeholder="Enter current password" />
                        <button class="btn toggle-btn" type="button" onclick="togglePassword('currentPassword', this)">
                            <i class="bi bi-eye-slash"></i>
                        </button>
                    </div>
                </div>

                <div class="col-md-8">
                    <label class="form-label fw-semibold">New Password</label>
                    <div class="input-group password-group">
                        <input type="password" name="newPassword" id="newPassword" class="form-control modern-input" placeholder="Enter new password" />
                        <button class="btn toggle-btn" type="button" onclick="togglePassword('newPassword', this)">
                            <i class="bi bi-eye-slash"></i>
                        </button>
                    </div>
                </div>

                <div class="col-md-8">
                    <label class="form-label fw-semibold">Confirm New Password</label>
                    <div class="input-group password-group">
                        <input type="password" name="confirmPassword" id="confirmPassword" class="form-control modern-input" placeholder="Confirm new password" />
                        <button class="btn toggle-btn" type="button" onclick="togglePassword('confirmPassword', this)">
                            <i class="bi bi-eye-slash"></i>
                        </button>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 justify-content-center mt-4">
                <button type="submit" class="btn save-btn">Save Password</button>
                @if (Context.Session.GetString("Role") == "IT")
                {
                    <a asp-controller="Admin" asp-action="Dashboard" class="btn cancel-btn">Back</a>
                }
                else
                {
                    <a asp-controller="Librarian" asp-action="Dashboard" class="btn cancel-btn">Back</a>
                }
            </div>
        </form>
    </div>
</div>

<style>
    .password-page-header h2 {
        color: #4a0f1d;
    }

    .password-card {
        background: #ffffff;
        border-radius: 24px;
        padding: 32px;
        box-shadow: 0 10px 30px rgba(60, 10, 18, 0.08);
        border: 1px solid #f1d9de;
        max-width: 900px;
        margin: 0 auto;
    }

    .modern-input {
        border-radius: 14px;
        border: 1px solid #e7c8cf;
        padding: 12px 14px;
        box-shadow: none;
        min-height: 48px;
    }

        .modern-input:focus {
            border-color: #8b1028;
            box-shadow: 0 0 0 0.2rem rgba(139, 16, 40, 0.12);
        }

    .custom-alert {
        border-radius: 14px;
        padding: 14px 16px;
    }

    .save-btn {
        background: #8b1028;
        color: #ffffff;
        border: none;
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
        min-width: 150px;
    }

        .save-btn:hover {
            background: #6d1023;
            color: #ffffff;
        }

    .cancel-btn {
        background: #f3f4f6;
        color: #374151;
        border: none;
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
        min-width: 100px;
    }

        .cancel-btn:hover {
            background: #e5e7eb;
            color: #111827;
        }

    .password-group .modern-input {
        border-top-right-radius: 0;
        border-bottom-right-radius: 0;
    }

    .toggle-btn {
        border: 1px solid #e7c8cf;
        border-left: none;
        background: #ffffff;
        color: #6d1023;
        border-top-right-radius: 14px;
        border-bottom-right-radius: 14px;
        min-width: 52px;
    }

        .toggle-btn:hover {
            background: #f9f1f3;
            color: #4a0f1d;
        }

        .toggle-btn:focus {
            box-shadow: 0 0 0 0.2rem rgba(139, 16, 40, 0.12);
        }

    .password-group .modern-input:focus + .toggle-btn {
        border-color: #8b1028;
    }

</style>

@section Scripts {
    <script>
        function togglePassword(fieldId, button) {
            var input = document.getElementById(fieldId);
            var icon = button.querySelector("i");

            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            } else {
                input.type = "password";
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            }
        }
    </script>
}