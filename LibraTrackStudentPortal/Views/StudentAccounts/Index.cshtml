@model IEnumerable<LibraTrackStudentPortal.Models.Student>

@{
    ViewData["Title"] = "Manage Student Accounts";
    var totalStudents = ViewBag.TotalStudents ?? 0;
    var activeStudents = ViewBag.ActiveStudents ?? 0;
    var deactivatedStudents = ViewBag.DeactivatedStudents ?? 0;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1">Manage Student Accounts</h2>
            <p class="text-muted mb-0">View, create, activate, and deactivate student accounts.</p>
        </div>

        <a asp-action="Create" class="btn create-btn">
            + Create Student Account
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="summary-card">
                <div class="summary-label">Total Students</div>
                <div class="summary-value">@totalStudents</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="summary-card">
                <div class="summary-label">Active</div>
                <div class="summary-value text-success">@activeStudents</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="summary-card">
                <div class="summary-label">Deactivated</div>
                <div class="summary-value text-danger">@deactivatedStudents</div>
            </div>
        </div>
    </div>

    <div class="table-tools mb-3">
        <div class="search-wrap">
            <i class="bi bi-search search-icon"></i>
            <input type="text"
                   id="searchInput"
                   class="form-control search-input"
                   placeholder="Search student..." />
        </div>
    </div>

    <div class="modern-table-card">
        <div class="table-responsive">
            <table class="table modern-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>ID Number</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model)
                    {
                        var safeId = ("stu_" + (student.ID_no ?? "unknown")).Replace("-", "_");

                        <tr class="clickable-row" onclick="toggleDetails('@safeId')">
                            <td class="fw-semibold">@student.ID_no</td>
                            <td>@student.full_name</td>
                            <td>@student.email</td>
                            <td>
                                @if (student.IsActive)
                                {
                                    <span class="status-badge active-badge">Active</span>
                                }
                                else
                                {
                                    <span class="status-badge inactive-badge">Deactivated</span>
                                }
                            </td>
                            <td class="text-center" onclick="event.stopPropagation();">
                                <div class="d-flex gap-2 justify-content-center flex-wrap">
                                    <a asp-action="Edit" asp-route-id="@student.ID_no" class="btn action-btn btn-warning">
                                        Edit
                                    </a>

                                    @if (!student.IsActive)
                                    {
                                        <a href="#"
                                           class="btn action-btn btn-activate"
                                           onclick="showConfirmModal('Activate this student account?', '@Url.Action("Activate", new { id = student.ID_no })')">
                                            Activate
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="#"
                                           class="btn action-btn btn-deactivate"
                                           onclick="showConfirmModal('Deactivate this student account?', '@Url.Action("Deactivate", new { id = student.ID_no })')">
                                            Deactivate
                                        </a>
                                    }

                                    <a href="#"
                                       class="btn action-btn btn-warning"
                                       onclick="showConfirmModal('Reset password for this student?', '@Url.Action("ResetPassword", new { id = student.ID_no })')">
                                        Reset Password
                                    </a>
                                </div>
                            </td>
                        </tr>

                        <tr id="details-@safeId" class="detail-row" style="display:none;">
                            <td colspan="5">
                                <div class="detail-card">
                                    <div class="row mb-3 detail-info">
                                        <div class="col-md-6">
                                            <div class="info-line"><strong>Student ID:</strong> @student.ID_no</div>
                                            <div class="info-line"><strong>Full Name:</strong> @student.full_name</div>
                                            <div class="info-line"><strong>Grade / Section:</strong> @student.grade_section</div>
                                        </div>

                                        <div class="col-md-6">
                                            <div class="info-line"><strong>Email:</strong> @student.email</div>
                                            <div class="info-line"><strong>Contact:</strong> @student.contact</div>
                                            <div class="info-line">
                                                <strong>Status:</strong>
                                                @(student.IsActive ? "Active" : "Deactivated")
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row detail-info">
                                        <div class="col-md-6">
                                            <div class="info-line"><strong>First Login:</strong> @(student.IsFirstLogin ? "Yes" : "No")</div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="info-line"><strong>Must Change Password:</strong> @(student.MustChangePassword ? "Yes" : "No")</div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="modal fade" id="confirmModal" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Confirm Action</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>

                        <div class="modal-body">
                            <p id="confirmMessage">Are you sure?</p>
                        </div>

                        <div class="modal-footer">
                            <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <a id="confirmBtn" class="btn btn-danger">Yes, Proceed</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.TotalPages > 1)
{
    <div class="d-flex justify-content-center align-items-center gap-2 mt-4 flex-wrap">
        @if (ViewBag.CurrentPage > 1)
        {
            <a href="@Url.Action("Index", "StudentAccounts", new { page = ViewBag.CurrentPage - 1 })" class="btn page-btn">
                Previous
            </a>
        }

        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            if (i == ViewBag.CurrentPage)
            {
                <span class="btn page-btn active-page">@i</span>
            }
            else
            {
                <a href="@Url.Action("Index", "StudentAccounts", new { page = i })" class="btn page-btn">
                    @i
                </a>
            }
        }

        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
        {
            <a href="@Url.Action("Index", "StudentAccounts", new { page = ViewBag.CurrentPage + 1 })" class="btn page-btn">
                Next
            </a>
        }
    </div>
}

<style>
    .summary-card {
        background: #ffffff;
        border-radius: 18px;
        padding: 20px 22px;
        box-shadow: 0 8px 24px rgba(60, 10, 18, 0.08);
        border: 1px solid #f1d9de;
    }

    .summary-label {
        font-size: 0.95rem;
        color: #7a4b55;
        margin-bottom: 8px;
    }

    .summary-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: #4a0f1d;
    }

    .create-btn {
        background: #6d1023;
        color: #ffffff;
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
        border: none;
    }

        .create-btn:hover {
            background: #56101d;
            color: #ffffff;
        }

    .modern-table-card {
        background: #ffffff;
        border-radius: 22px;
        box-shadow: 0 10px 30px rgba(60, 10, 18, 0.08);
        border: 1px solid #f1d9de;
        overflow: hidden;
    }

    .modern-table thead th {
        background: #f7e6ea;
        color: #4a0f1d;
        font-weight: 800;
        font-size: 0.95rem;
        border-bottom: 1px solid #e8c8cf;
        padding: 18px 14px;
    }

    .modern-table tbody td {
        padding: 18px 14px;
        border-color: #f6ecef;
        vertical-align: middle;
    }

    .modern-table tbody tr:hover {
        background: #fff8f9;
        cursor: pointer;
    }

    .detail-row td {
        background: #fffafb;
    }

    .detail-card {
        background: #fffdfd;
        border: 1px solid #f1d9de;
        border-radius: 16px;
        padding: 18px;
    }

    .detail-info .info-line {
        margin-bottom: 10px;
        font-size: 1rem;
    }

    .status-badge {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 700;
    }

    .active-badge {
        background: rgba(34, 197, 94, 0.12);
        color: #15803d;
    }

    .inactive-badge {
        background: rgba(109, 16, 35, 0.12);
        color: #8b1028;
    }

    .action-btn {
        min-width: 120px;
        border-radius: 12px;
        font-weight: 600;
        padding: 8px 14px;
        border: none;
    }

    .btn-activate {
        background: #15803d;
        color: white;
    }

        .btn-activate:hover {
            background: #166534;
            color: white;
        }

    .btn-deactivate {
        background: #8b1028;
        color: white;
    }

        .btn-deactivate:hover {
            background: #6d1023;
            color: white;
        }

    .table-tools {
        display: flex;
        justify-content: flex-end;
        align-items: center;
    }

    .search-wrap {
        position: relative;
        width: 320px;
    }

    .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #8b1028;
        font-size: 0.95rem;
    }

    .search-input {
        border-radius: 14px;
        border: 1px solid #e7c8cf;
        padding: 12px 14px 12px 40px;
        min-height: 48px;
        box-shadow: 0 4px 14px rgba(60, 10, 18, 0.05);
        background: #fffdfd;
    }

        .search-input:focus {
            border-color: #8b1028;
            box-shadow: 0 0 0 0.2rem rgba(139, 16, 40, 0.12);
        }

    .page-btn {
        border: 1px solid #e7c8cf;
        background: #ffffff;
        color: #6d1023;
        border-radius: 10px;
        min-width: 44px;
        font-weight: 600;
        padding: 8px 14px;
    }

        .page-btn:hover {
            background: #f9f1f3;
            color: #4a0f1d;
        }

    .active-page {
        background: #8b1028 !important;
        color: #ffffff !important;
        border-color: #8b1028 !important;
        cursor: default;
    }

</style>

<script>
    function showConfirmModal(message, url) {
        document.getElementById("confirmMessage").innerText = message;
        document.getElementById("confirmBtn").setAttribute("href", url);

        var modal = new bootstrap.Modal(document.getElementById('confirmModal'));
        modal.show();
    }

    function toggleDetails(id) {
        const row = document.getElementById("details-" + id);
        if (!row) return;

        if (row.style.display === "none" || row.style.display === "") {
            row.style.display = "table-row";
        } else {
            row.style.display = "none";
        }
    }

    document.getElementById("searchInput").addEventListener("keyup", function () {
        let filter = this.value.toLowerCase();
        let rows = document.querySelectorAll(".clickable-row");

        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            let safeId = ("stu_" + ((row.cells[0].innerText || "").trim())).replace(/-/g, "_");
            let detailRow = document.getElementById("details-" + safeId);

            if (text.includes(filter)) {
                row.style.display = "";
            } else {
                row.style.display = "none";
                if (detailRow) detailRow.style.display = "none";
            }
        });
    });
</script>